# === Databricks Connection ===
# Option A: Service principal (recommended for production)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_CLIENT_ID=your-sp-client-id
DATABRICKS_CLIENT_SECRET=your-sp-client-secret

# Option B: Personal access token (for testing)
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...

# Orchestrator endpoint name (from your deployment config)
ORCHESTRATOR_ENDPOINT=your-app-name-orchestrator-agent

# === Azure Bot Service ===
# From your Entra ID App Registration
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=your-entra-app-id
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=your-entra-client-secret
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=your-tenant-id

# For local testing without Azure auth (comment out the above):
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__ANONYMOUS_ALLOWED=True

# Bot server port
PORT=3978
